{
  "schemaVersion": "1.0.0",
  "name": "complete-example",
  "version": "1.0.0",
  "inputs": [
    {
      "name": "inputValue",
      "type": "string",
      "description": "Example input parameter",
      "required": true
    }
  ],
  "phases": [
    {
      "name": "plan",
      "description": "Planning phase"
    },
    {
      "name": "execute",
      "description": "Execution phase"
    }
  ],
  "gates": [
    {
      "name": "validation-gate",
      "description": "Validates inputs"
    }
  ],
  "artifacts": [
    {
      "name": "output-file",
      "path": "outputs/result.json",
      "description": "Generated output file"
    }
  ],
  "hooks": {
    "onLoad": "onLoad",
    "beforeExecute": "beforeExecute",
    "afterPublish": "afterPublish"
  },
  "binds": {
    "declares": ["logger", "config"],
    "override": ["shared-utils"]
  },
  "config_schema": {
    "type": "object",
    "properties": {
      "timeout": { "type": "number" }
    }
  },
  "migrations": [
    {
      "version": "1.0.0",
      "strategy": "noop",
      "description": "No-op baseline migration"
    },
    {
      "version": "2.0.0",
      "strategy": "script",
      "path": "migrations/v2.js",
      "description": "Script-based migration to v2"
    },
    {
      "version": "3.0.0",
      "strategy": "manual",
      "instructions": "Review and update config manually",
      "description": "Manual migration to v3"
    }
  ],
  "tests": [
    {
      "name": "unit-tests",
      "path": "tests/unit.test.ts",
      "description": "Unit test suite"
    },
    {
      "name": "integration-tests",
      "path": "tests/integration.test.ts"
    }
  ]
}
